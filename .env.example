# ===========================================
# Outline Configuration
# ===========================================

# --- Docker Images ---
# Pin to a vendored digest for reproducibility:
# Example: ghcr.io/korjavin/outline-vendor:latest@sha256:<digest>
OUTLINE_IMAGE=ghcr.io/korjavin/outline-vendor:latest
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# --- Container Names ---
OUTLINE_CONTAINER_NAME=outline
DB_CONTAINER_NAME=outline-db
REDIS_CONTAINER_NAME=outline-redis

# --- Network Names ---
INTERNAL_NETWORK_NAME=outline_internal
TRAEFIK_NETWORK_NAME=traefik_default

# --- Volume Names ---
DB_VOLUME_NAME=outline_db-data

# --- Traefik Configuration ---
OUTLINE_HOST=outline.yourdomain.com
TRAEFIK_CERTRESOLVER=myresolver

# --- OAuth Proxy / Forward Auth (Optional) ---
# If using oauth2-proxy or Authentik forward-auth at the Traefik level,
# set OAUTH_PROXY=true and specify the middleware name below.
# Leave TRAEFIK_MIDDLEWARES empty (or unset) when not using forward-auth.
# OAUTH_PROXY=true
TRAEFIK_MIDDLEWARES=

# --- Data Storage ---
DATA_PATH=./data

# --- Secrets (REQUIRED) ---
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
UTILS_SECRET=change-me-generate-with-openssl-rand-hex-32

# --- Database ---
POSTGRES_DB=outline
POSTGRES_USER=outline
POSTGRES_PASSWORD=change-me-to-strong-password

# --- Authentik OIDC ---
# Create an OAuth2/OIDC provider in Authentik, then fill in these values.
# Authentik provider URLs follow the pattern:
#   https://auth.yourdomain.com/application/o/<slug>/
OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=change-me
OIDC_AUTH_URI=https://auth.yourdomain.com/application/o/authorize/
OIDC_TOKEN_URI=https://auth.yourdomain.com/application/o/token/
OIDC_USERINFO_URI=https://auth.yourdomain.com/application/o/userinfo/
OIDC_USERNAME_CLAIM=preferred_username
OIDC_DISPLAY_NAME=Authentik
OIDC_SCOPES=openid profile email

# --- File Storage ---
# Max upload size in bytes (default: 25 MB)
FILE_STORAGE_UPLOAD_MAX_SIZE=26214400

# --- Email / SMTP (Optional) ---
# Leave blank to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_REPLY_EMAIL=
SMTP_SECURE=false

# --- Optional Application Settings ---
DEFAULT_LANGUAGE=en_US
# Set false when behind a TLS-terminating reverse proxy (Traefik handles HTTPS)
FORCE_HTTPS=false
ENABLE_UPDATES=false
WEB_CONCURRENCY=1
LOG_LEVEL=info

# --- Database Pool (Optional) ---
DATABASE_CONNECTION_POOL_MIN=
DATABASE_CONNECTION_POOL_MAX=
